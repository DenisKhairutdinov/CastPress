{% set pageTitle = "Home" %}
{% set bodyClass = "default" %}
{% extends "layout.njk" %}

{% block content %}
  <section class="hero container main-page-section">
    <header class="episode-header hero__episode">
      <picture class="episode-header__cover-wrapper">
        <source
          class="episode-header__cover-webp"
          srcset=""
          type="image/webp"
          data-hero-image-webp
        />
        <img
          class="episode-header__cover"
          src=""
          alt="episode cover"
          decoding="sync"
          width="180"
          height="180"
          fetchpriority="high"
          data-hero-image
        />
      </picture>
      <a href="#" class="episode-header__link" data-hero-link>
        <h1 class="episode-header__title" data-hero-title>Title</h1>
      </a>

      <p class="episode-header__info" data-hero-info>Episode 18 | Jan 8, 2021 | By VitaThemes</p>

      <div class="player episode-header__player hero__player" data-player>
        <audio src="" class="player__audio" data-hero-player data-player-audio></audio>
        <button
          class="player__play-pause-button"
          type="button"
          aria-label="play/pause"
          data-play-pause-button
        >
          <svg class="player__play-pause-icon" data-play-pause-icon>
            <use href="#icon-player-play"></use>
            <use href="#icon-player-pause" hidden></use>
          </svg>
        </button>
        <span class="player__current-time" data-current-time>00:00</span>
        <input
          class="player__progress"
          type="range"
          min="0"
          max="100"
          value="0"
          aria-label="audio progress"
          aria-valuetext="0 hours 0 minutes 0 seconds"
          data-progress
        />
        <span class="player__duration" data-duration>01:00</span>
        <button class="player__mute-button" type="button" aria-label="mute/unmute" data-mute-button>
          <svg class="player__mute-icon" data-mute-icon>
            <use href="#icon-player-unmute"></use>
            <use href="#icon-player-mute" hidden></use>
          </svg>
        </button>
      </div>

      <div class="streaming episode-header__streaming">
        <p class="streaming__text">listen on</p>
        <ul class="streaming__list">
          <li class="streaming__item">
            <a
              href=""
              class="streaming__link"
              target="_blank"
              rel="noopener noreferrer"
              data-name="spotify"
              aria-label="go to spotify stream"
              data-hero-streaming-link
            >
              <svg class="streaming__icon" aria-hidden="true">
                <use href="#icon-stremaing-spotify"></use>
              </svg>
            </a>
          </li>
          <li class="streaming__item">
            <a
              href=""
              class="streaming__link"
              target="_blank"
              rel="noopener noreferrer"
              data-name="soundcloud"
              data-hero-streaming-link
            >
              <svg class="streaming__icon" aria-hidden="true">
                <use href="#icon-stremaing-soundcloude"></use>
              </svg>
            </a>
          </li>
          <li class="streaming__item">
            <a
              href=""
              class="streaming__link"
              target="_blank"
              rel="noopener noreferrer"
              data-name="appleMusic"
              data-hero-streaming-link
            >
              <svg class="streaming__icon" aria-hidden="true">
                <use href="#icon-stremaing-apple-music"></use>
              </svg>
            </a>
          </li>
        </ul>
      </div>
    </header>
  </section>

  <section class="episodes container episodes--block-padding main-page-section">
    <ul class="episodes-list episodes__episodes-list" data-episodes-list></ul>
    <nav class="pagination episodes__pagination" data-pagination>
      <button
        class="pagination__arrow pagination__arrow--left-arrow pagination__arrow--unactive"
        type="button"
        aria-label="previous"
        data-arrow="left-arrow"
        data-pagination-left-arrow
      >
        <svg class="pagination__arrow-icon" aria-hidden="true">
          <use href="#icon-pagination-arrow"></use>
        </svg>
      </button>
      <div class="pagination__wrapper" data-pagination-wrapper>
        <div class="pagination__central-buttons" data-central-buttons></div>
      </div>
      <button
        class="pagination__arrow pagination__arrow--right-arrow"
        type="button"
        aria-label="previous"
        data-arrow="right-arrow"
        data-pagination-right-arrow
      >
        <svg class="pagination__arrow-icon" aria-hidden="true">
          <use href="#icon-pagination-arrow"></use>
        </svg>
      </button>
    </nav>
  </section>

  <section class="team-section container main-page-section">
    <h2 class="team-section__title">Team</h2>
    <ul class="team">
      <li class="team__item">
        <article class="team__card">
          <picture class="team__photo-wrapper">
            <source srcset="/src/assets/images/team/Nick-Carleton.webp" type="image/webp" />
            <img
              class="team__photo"
              src="/src/assets/images/team/Nick-Carleton.png"
              alt="Nick Carleton, producer"
              loading="lazy"
              decoding="async"
              width="288"
              height="288"
            />
          </picture>
          <div class="team__info">
            <p class="team__position">producer</p>
            <h3 class="team__name">Nick Carleton</h3>
            <p class="team__description">
              He plans episodes, coordinates guests, manages production, and ensures every release
              meets the highest standards.
            </p>
            <ul class="team__social-links">
              <li class="team__social-item">
                <a
                  href="https://www.linkedin.com/"
                  class="team__social-link"
                  aria-label="go to LinkedIn"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <svg class="team__social-icon" aria-hidden="true">
                    <use href="#icon-team-linkedin"></use>
                  </svg>
                </a>
              </li>
              <li class="team__social-item">
                <a
                  href="https://github.com/"
                  class="team__social-link"
                  aria-label="go to GitHub"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <svg class="team__social-icon" aria-hidden="true">
                    <use href="#icon-team-github"></use>
                  </svg>
                </a>
              </li>
              <li class="team__social-item">
                <a
                  href="https://x.com/"
                  class="team__social-link"
                  aria-label="go to twitter"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <svg class="team__social-icon" aria-hidden="true">
                    <use href="#icon-team-twitter"></use>
                  </svg>
                </a>
              </li>
            </ul>
          </div>
        </article>
      </li>

      <li class="team__item">
        <article class="team__card">
          <picture class="team__photo-wrapper">
            <source srcset="/src/assets/images/team/Aida-Cave.webp" type="image/webp" />
            <img
              class="team__photo"
              src="/src/assets/images/team/Aida-Cave.png"
              alt="Aida Cave, host"
              loading="lazy"
              decoding="async"
              width="288"
              height="288"
            />
          </picture>
          <div class="team__info">
            <p class="team__position">host</p>
            <h3 class="team__name">Aida Cave</h3>
            <p class="team__description">
              She leads the conversation, sets the tone, and creates a natural, engaging atmosphere
              for every episode.
            </p>
            <ul class="team__social-links">
              <li class="team__social-item">
                <a
                  href="https://www.linkedin.com/"
                  class="team__social-link"
                  aria-label="go to LinkedIn"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <svg class="team__social-icon" aria-hidden="true">
                    <use href="#icon-team-linkedin"></use>
                  </svg>
                </a>
              </li>
              <li class="team__social-item">
                <a
                  href="https://github.com/"
                  class="team__social-link"
                  aria-label="go to GitHub"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <svg class="team__social-icon" aria-hidden="true">
                    <use href="#icon-team-github"></use>
                  </svg>
                </a>
              </li>
              <li class="team__social-item">
                <a
                  href="https://x.com/"
                  class="team__social-link"
                  aria-label="go to twitter"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <svg class="team__social-icon" aria-hidden="true">
                    <use href="#icon-team-twitter"></use>
                  </svg>
                </a>
              </li>
            </ul>
          </div>
        </article>
      </li>
    </ul>
  </section>

  <section class="latest-posts container main-page-section">
    <h2 class="latest-posts__title">Latest Posts</h2>
    <ul class="blog-list" data-blog-list></ul>
    <a
      href="/CastPress/blog"
      class="custom-button latest-posts__custom-button custom-button--light"
    >
      <span class="custom-button__text">View Blog</span>
      <svg class="custom-button__icon custom-button__icon--accent" aria-hidden="true">
        <use href="#icon-custom-button-arrow"></use>
      </svg>
    </a>
  </section>
{% endblock %}
