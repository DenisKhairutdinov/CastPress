<footer class="footer">
  <div class="footer__wrapper">
    <nav class="footer__menu">
      <ul class="footer__menu-list">
        <li class="footer__menu-item">
          <a href="/episodes" class="footer__menu-link">Episodes</a>
        </li>
        <li class="footer__menu-item">
          <a href="/blog" class="footer__menu-link">Blog</a>
        </li>
        <li class="footer__menu-item">
          <a href="/about" class="footer__menu-link">About</a>
        </li>
        <li class="footer__menu-item">
          <a href="/contact" class="footer__menu-link">Contact</a>
        </li>
        <li class="footer__menu-item">
          <a href="/donate" class="footer__menu-link">Donate</a>
        </li>
      </ul>
    </nav>

    <div class="footer__newsletter">
      <h2 class="footer__newsletter-title">Newsletter</h2>
      <p class="footer__newsletter-text">Sign up now; get closer to our action.</p>

      <form action="#" class="form footer__form" method="POST" data-form>
        <label class="form__label form__label--hidden" for="email">Email address</label>
        <div class="form__group">
          <input
            id="email"
            class="form__input"
            name="email"
            type="email"
            placeholder="Email address..."
            required
            aria-describedby="error-empty error-invalid"
            aria-invalid="false"
            autocomplete="email"
          />

          <span id="error-empty" class="form__error form__error--empty"
            >* This field is required to proceed</span
          >
          <span id="error-invalid" class="form__error form__error--invalid"
            >* Please enter a valid email address</span
          >
        </div>
        <button class="custom-button footer__custom-button" type="submit" aria-label="Submit email">
          <svg class="custom-button__icon" aria-hidden="true">
            <use href="#icon-footer-arrow"></use>
          </svg>
        </button>

        <p class="form__message form__message--hidden" aria-live="polite" data-form-message>
          Thanks for joining! You're on the list!
        </p>
      </form>
    </div>

    <p class="footer__description">
      PodcastTheme by
      <a href="#" class="footer__description-link" target="_blank" rel="noopener noreferrer"
        >VitaThemes</a
      >
      |
      <a class="footer__description-link" href="/privacy-policy">Privacy policy</a>
    </p>

    <div class="footer__socials">
      <a
        href="https://www.facebook.com/"
        class="footer__social-link"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="go to facebook"
      >
        <svg class="footer__social-icon" aria-hidden="true">
          <use href="#icon-footer-facebook"></use>
        </svg>
      </a>
      <a
        href="https://github.com/"
        class="footer__social-link"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="go to github"
      >
        <svg class="footer__social-icon" aria-hidden="true">
          <use href="#icon-footer-github"></use>
        </svg>
      </a>
      <a
        href="https://x.com/"
        class="footer__social-link"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="go to twitter"
      >
        <svg class="footer__social-icon" aria-hidden="true">
          <use href="#icon-footer-twitter"></use>
        </svg>
      </a>
    </div>
  </div>
</footer>
